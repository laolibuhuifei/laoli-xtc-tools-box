<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="4dp"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textColor="#333333"
            android:textStyle="bold" />

        <!-- 浏览器功能入口 -->
        <Button
            android:id="@+id/btn_open_browser"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/btn_open_browser"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/browaer3"
            android:layout_marginBottom="20dp"/>

        <!-- 活动打开器入口 -->
        <Button
            android:id="@+id/btn_activity_launcher"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/btn_activity_launcher"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/open30px"
            android:layout_marginBottom="20dp"/>

        <!-- WiFi ADB 调试 (新增滑块开关) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/browser_edit_bg">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_wifi_adb"
                android:textColor="#000000"
                android:textSize="12sp" />
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_wifi_adb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
        <TextView
            android:id="@+id/tv_wifi_adb_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/wifi_adb_off"
            android:textColor="#666666"
            android:textSize="11sp"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="20dp" />

        <!-- 弹窗部分 -->
        <EditText
            android:id="@+id/tanchuang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="@string/hint_popup"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/bt_android"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:text="@string/button_popup"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="20dp"/>

        <!-- 快捷按钮 -->
        <Button
            android:id="@+id/btn_open"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:text="@string/btn_alarm"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/open30px"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_open2"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:text="@string/btn_medical"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/open30px"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_open4"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:text="@string/btn_selftest"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/open30px"
            android:layout_marginBottom="8dp"/>

        <!-- 切换输入法按钮 -->
        <Button
            android:id="@+id/btn_switch_ime"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:text="@string/btn_switch_ime"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/setting30px"
            android:layout_marginBottom="20dp"/>

        <!-- DPI 部分 -->
        <EditText
            android:id="@+id/et_dpi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="@string/hint_dpi"
            android:inputType="number"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_set_dpi"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:text="@string/btn_set_dpi"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/setting30px"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_reset_dpi"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:text="@string/btn_reset_dpi"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/setting30px"
            android:layout_marginBottom="20dp"/>

        <!-- 电量部分 -->
        <EditText
            android:id="@+id/et_battery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="@string/hint_battery"
            android:inputType="number"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_set_battery"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:text="@string/btn_set_battery"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/setting30px"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_reset_battery"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:text="@string/btn_reset_battery"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/setting30px"
            android:layout_marginBottom="20dp"/>

        <!-- 触屏轨迹 -->
        <Button
            android:id="@+id/btn_show_touch"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:text="@string/btn_show_touch"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/setting30px"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_hide_touch"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:text="@string/btn_hide_touch"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/setting30px"
            android:layout_marginBottom="20dp"/>

        <!-- 短信压力测试 -->
        <Button
            android:id="@+id/btn_open_web"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:text="@string/btn_sms_test"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/setting30px"
            android:layout_marginBottom="20dp"/>

        <!-- Shell 部分 -->
        <EditText
            android:id="@+id/et_cmd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="@string/hint_shell"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_exec_cmd"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:text="@string/btn_exec_shell"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/command"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tv_shell_output"
            android:padding="8dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="20dp"/>

        <!-- 关于按钮 -->
        <Button
            android:id="@+id/btn_jump"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:text="@string/btn_lab"
            android:textColor="#000000"
            android:textSize="12sp"
            app:strokeColor="#000000"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:drawableLeft="@drawable/i2"
            android:layout_marginBottom="40dp"/>

    </LinearLayout>
</ScrollView>